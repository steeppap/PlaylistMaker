<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MediaLibraryActivity">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        style="@style/MainMenuBackground"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/panel_header_height">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginStart="16dp"
                android:layout_marginTop="14dp"
                android:text="@string/app_name"
                android:fontFamily="@font/ys_display_medium"
                android:textFontWeight="500"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_main" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="@dimen/indentation_from_header_panel"
            android:layout_marginBottom="28dp"
            android:orientation="vertical">

            <Button
                style="@style/ButtonMainMenu"
                android:id="@+id/search_button"

                android:text="@string/search"

                app:icon="@drawable/ic_search_24" />

            <Button
                style="@style/ButtonMainMenu"
                android:id="@+id/media_library_button"

                android:text="@string/media_library"

                app:icon="@drawable/ic_library_24" />

            <Button
                style="@style/ButtonMainMenu"
                android:id="@+id/settings_button"
                android:layout_marginBottom="0dp"

                android:text="@string/settings"

                app:icon="@drawable/ic_settings_24" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
