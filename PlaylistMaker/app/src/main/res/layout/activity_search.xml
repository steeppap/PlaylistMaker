<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".search.ui.activity.SearchActivity">

    <LinearLayout
        style="@style/OtherScreensBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout

            android:layout_width="match_parent"
            android:layout_height="@dimen/panel_header_height"
            android:orientation="vertical">

            <LinearLayout

                style="@style/OtherScreensBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginVertical="@dimen/header_margin_vertical_and_start"
                android:layout_marginStart="@dimen/header_margin_vertical_and_start"
                android:layout_marginEnd="@dimen/header_margin_end"
                android:orientation="horizontal">

                <FrameLayout

                    android:layout_width="@dimen/back_butt_layout_width"
                    android:layout_height="match_parent">

                    <ImageView

                        style="@style/HeaderPanelElementsColor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_back_24" />

                    <Button

                        android:id="@+id/back_button"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:foreground="?attr/selectableItemBackground" />

                </FrameLayout>

                <FrameLayout

                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView

                        style="@style/HeaderPanelElementsColor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/head_text_margin_start_and_bot"
                        android:layout_marginTop="@dimen/head_text_margin_top"
                        android:layout_marginBottom="@dimen/head_text_margin_start_and_bot"
                        android:fontFamily="@font/ys_display_medium"
                        android:text="@string/search"
                        android:textFontWeight="500"
                        android:textSize="@dimen/text_size_main" />

                </FrameLayout>

            </LinearLayout>

        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp">

            <EditText
                android:id="@+id/search_edit_text"
                style="@style/RoundedEditText"
                android:focusable="true"
                android:hint="@string/search"
                android:imeOptions="actionDone"
                android:singleLine="true">

            </EditText>

            <ImageView
                android:id="@+id/clear_btn"
                style="@style/ClearIcon" />

        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/history_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/NothingFoundAndConnectionErrorTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/header_margin_end"
                    android:layout_marginTop="@dimen/ic_size_24"
                    android:layout_marginBottom="8dp"
                    android:text="@string/history_title"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewHistory"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

                <Button
                    style="@style/UpdateButtonStyle"
                    android:id="@+id/clear_history_btn"
                    android:text="@string/clear_history" />

            </LinearLayout>

            <include
                android:id="@+id/nothingFound"
                layout="@layout/nothing_found_error" />
            <include
                android:id="@+id/connectionError"
                layout="@layout/connection_error" />

            <androidx.recyclerview.widget.RecyclerView
                android:visibility="gone"
                android:id="@+id/recyclerViewTrackList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            <ProgressBar
                style="@style/OtherScreensBackground"
                android:id="@+id/progressBar"
                android:layout_width="@dimen/ic_size_44"
                android:layout_height="@dimen/ic_size_44"
                android:layout_gravity="center"
                android:indeterminateTint="@color/thumb_tint_dark_mode"
                android:background="@android:color/transparent"
                android:visibility="gone"/>
        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
