<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:id="@+id/emptyPlaylists"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <Button
        style="@style/UpdateButtonStyle"
        android:id="@+id/newPlaylist"
        android:text="@string/new_playlist"
        android:layout_marginTop="@dimen/margin_16"
        android:layout_marginBottom="@dimen/margin_46"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:src="@drawable/ic_not_found_120" />

    <TextView
        style="@style/NothingFoundAndConnectionErrorTextStyle"
        android:text="@string/empty_playlists" />

</LinearLayout>
