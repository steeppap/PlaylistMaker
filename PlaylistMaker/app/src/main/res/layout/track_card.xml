<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/OtherScreensBackground"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    tools:context=".SearchActivity">

    <ImageView
        android:id="@+id/track_cover"
        android:layout_width="@dimen/track_icon"
        android:layout_height="@dimen/track_icon"
        android:layout_marginVertical="@dimen/icon_padding"
        android:layout_marginStart="13dp"
        android:layout_marginEnd="@dimen/icon_padding" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginVertical="14dp"
        android:layout_marginEnd="@dimen/icon_padding"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/track_name"
            style="@style/TextViewTrackName" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/artist_name"
                style="@style/TextViewArtistNameAndTime" />

            <ImageView
                style="@style/IconInFrameLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_point_13" />

            <TextView
                android:id="@+id/track_time"
                style="@style/TextViewArtistNameAndTime"
                android:layout_weight="0" />

        </LinearLayout>

    </LinearLayout>

    <ImageView
        style="@style/IconInFrameLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_arrow_forward_24" />

</LinearLayout>
