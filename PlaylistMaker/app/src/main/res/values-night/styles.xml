<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="MainMenuBackground">
        <item name="android:background">@color/black_button_text</item>
    </style>

    <style name="OtherScreensBackground">
        <item name="android:background">@color/black_button_text</item>
    </style>

    <style name="HeaderPanelElementsColor">
        <item name="tint">@color/white</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="ButtonMainMenu" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="backgroundTint">@color/white</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="cornerRadius">@dimen/button_radius</item>

        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/icon_padding</item>
        <item name="iconTint">@color/black_button_text</item>

        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textColor">@color/black_button_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textSize">@dimen/text_size_main</item>
    </style>

    <style name="SwitchStyle">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_gravity">end</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:layout_marginBottom">11dp</item>
        <item name="android:checked">true</item>
        <item name="android:thumbTint">@color/thumb_tint_dark_mode</item>
        <item name="android:trackTint">@color/track_tint_dark_mode</item>
    </style>

    <style name="TextSettingsItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_gravity">start</item>
        <item name="android:layout_marginStart">@dimen/margin_16</item>
        <item name="android:layout_marginVertical">@dimen/layout_marginVertical_settings_point</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">@dimen/text_size_settings_point</item>
    </style>

    <style name="LocationIconFrameLayout">
        <item name="android:layout_width">@dimen/ic_size_24</item>
        <item name="android:layout_height">@dimen/ic_size_24</item>
        <item name="android:layout_gravity">end</item>
        <item name="android:layout_marginTop">@dimen/layout_marginTop_settings_icon</item>
        <item name="android:layout_marginEnd">@dimen/layout_marginEnd_settings_icon</item>
    </style>
    
    <style name="IconInFrameLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_gravity">center</item>
        <item name="tint">@color/white</item>
    </style>

    <style name="RoundedEditText" parent="@android:style/Widget.EditText">
        <item name="android:background">@drawable/rounded_background</item>
        <item name="android:textCursorDrawable">@drawable/cursor</item>
        <item name="android:textColorHighlight">@color/track_tint_dark_mode</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_marginHorizontal">16dp</item>
        <item name="android:layout_marginVertical">8dp</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textColor">@color/black_button_text</item>
        <item name="android:textSize">@dimen/text_size_settings_point</item>
        <item name="android:textColorHint">@color/black_button_text</item>
        <item name="android:maxLines">1</item>
        <item name="android:inputType">text</item>
        <item name="android:drawableStart">@drawable/ic_search_16</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:drawablePadding">8dp</item>
    </style>

    <style name="ClearIcon">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginVertical">18dp</item>
        <item name="android:layout_marginEnd">28dp</item>
        <item name="android:layout_gravity">end</item>
        <item name="android:src">@drawable/ic_clear_16</item>
        <item name="android:visibility">gone</item>
    </style>

    <style name="TextViewTrackName">
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:maxLines">1</item>
        <item name="android:textSize">@dimen/text_size_settings_point</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="TextViewArtistNameAndTime" parent="TextViewTrackName">
        <item name="android:textSize">11sp</item>
    </style>

    <style name="NothingFoundAndConnectionErrorTextStyle" parent="TextViewTrackName">
        <item name="android:textColor">@color/white</item>
        <item name="android:maxLines">4</item>
        <item name="android:layout_weight">0</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_19</item>
        <item name="android:layout_marginTop">@dimen/margin_16</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="UpdateButtonStyle" parent="ButtonMainMenu">
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_weight">0</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:textColor">@color/black_button_text</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">54dp</item>
        <item name="android:layout_marginTop">@dimen/ic_size_24</item>

    </style>

</resources>
